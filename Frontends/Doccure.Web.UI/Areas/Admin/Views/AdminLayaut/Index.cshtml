@model Doccure.Web.UI.ViewModels.Dashboard.DashboardViewModel
@{
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<!-- Statistika Kartları -->
<div class="row g-4 mb-4">
    <div class="col-12 col-sm-6 col-xl-3">
        <div class="stat-card">
            <div class="stat-info">
                <div class="stat-value">@Model.DoctorCount</div>
                <div class="stat-label">Ümumi Həkim</div>
            </div>
            <div class="stat-icon icon-blue">
                <i class="bi bi-person-fill-gear"></i>
            </div>
        </div>
    </div>

    <div class="col-12 col-sm-6 col-xl-3">
        <div class="stat-card">
            <div class="stat-info">
                <div class="stat-value">@Model.AppointmentCount</div>
                <div class="stat-label">Ümumi Görüş</div>
            </div>
            <div class="stat-icon icon-teal">
                <i class="bi bi-calendar-event"></i>
            </div>
        </div>
    </div>

    <div class="col-12 col-sm-6 col-xl-3">
        <div class="stat-card">
            <div class="stat-info">
                <div class="stat-value">@Model.BranchCount</div>
                <div class="stat-label">Ümumi Şöbə</div>
            </div>
            <div class="stat-icon icon-yellow">
                <i class="bi bi-hospital"></i>
            </div>
        </div>
    </div>

    <div class="col-12 col-sm-6 col-xl-3">
        <div class="stat-card">
            <div class="stat-info">
                <div class="stat-value">@Model.PatientCount</div>
                <div class="stat-label">Ümumi Xəstə</div>
            </div>
            <div class="stat-icon icon-red">
                <i class="bi bi-people-fill"></i>
            </div>
        </div>
    </div>
</div>

<!-- Əsas Məzmun -->
<div class="row g-4">

    <!-- Son Görüşlər -->
    <div class="col-12 col-xl-7">
        <div class="content-card h-100">
            <div class="card-header-custom">
                <h5 class="card-title-custom">
                    <i class="bi bi-calendar-check-fill"></i>
                    Son Görüşlər
                </h5>
                <a asp-area="Admin" asp-controller="Appointment" asp-action="Index"
                   class="btn btn-sm btn-outline-primary rounded-pill px-3">Hamısına bax</a>
            </div>
            <div class="table-responsive">
                <table class="table table-custom align-middle">
                    <thead>
                        <tr>
                            <th>#</th>
                            <th>Həkim ID</th>
                            <th>Xəstə ID</th>
                            <th>Tarix</th>
                            <th>Məbləğ</th>
                            <th>Vəziyyət</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.RecentAppointments.Any())
                        {
                            @foreach (var a in Model.RecentAppointments)
                            {
                                var statusClass = a.Status?.ToLower() switch
                                {
                                    "confirmed" or "təsdiqləndi" => "badge-active",
                                    "pending" or "gözləyir" => "badge-pending",
                                    "cancelled" or "ləğv edildi" => "badge-cancelled",
                                    _ => "badge-pending"
                                };
                                var statusLabel = a.Status?.ToLower() switch
                                {
                                    "confirmed" => "Təsdiqləndi",
                                    "pending" => "Gözləyir",
                                    "cancelled" => "Ləğv edildi",
                                    _ => a.Status ?? "—"
                                };
                                <tr>
                                    <td class="text-muted" style="font-size:.82rem;">#@a.AppointmentId</td>
                                    <td>
                                        <div class="d-flex align-items-center gap-2">
                                            <div class="avatar-circle bg-primary-subtle text-primary">
                                                @(a.DoctorId?.Length > 1 ? a.DoctorId.Substring(0,2).ToUpper() : "Dr")
                                            </div>
                                            <span class="fw-500" style="font-size:.83rem;">
                                                @(a.DoctorId?.Length > 8 ? a.DoctorId.Substring(0,8) + "…" : a.DoctorId)
                                            </span>
                                        </div>
                                    </td>
                                    <td style="font-size:.83rem;color:#475569;">
                                        @(a.PatientId?.Length > 8 ? a.PatientId.Substring(0,8) + "…" : a.PatientId)
                                    </td>
                                    <td style="font-size:.82rem;">@a.AppointmentDate.ToString("dd MMM yyyy, HH:mm")</td>
                                    <td style="font-weight:600;color:#16a34a;">₼@a.Price.ToString("F2")</td>
                                    <td><span class="badge-status @statusClass">@statusLabel</span></td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="6" class="text-center text-muted py-4">
                                    <i class="bi bi-calendar-x d-block fs-3 mb-2"></i>
                                    Görüş tapılmadı
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <!-- Ən Yaxşı Həkimlər -->
    <div class="col-12 col-xl-5">
        <div class="content-card h-100">
            <div class="card-header-custom">
                <h5 class="card-title-custom">
                    <i class="bi bi-person-fill-gear"></i>
                    Həkimlər
                </h5>
                <a asp-area="Admin" asp-controller="Doctor" asp-action="Index"
                   class="btn btn-sm btn-outline-primary rounded-pill px-3">Hamısına bax</a>
            </div>
            <div class="doctor-list">
                @if (Model.TopDoctors.Any())
                {
                    @foreach (var doc in Model.TopDoctors)
                    {
                        <div class="doctor-item">
                            @if (!string.IsNullOrEmpty(doc.ImageUrl))
                            {
                                <img src="@doc.ImageUrl" alt="@doc.Name @doc.Surname" class="doctor-avatar"
                                     onerror="this.style.display='none';this.nextElementSibling.style.display='flex';">
                                <div class="avatar-circle bg-primary-subtle text-primary" style="display:none;width:48px;height:48px;flex-shrink:0;">
                                    @(doc.Name?.Substring(0,1))@(doc.Surname?.Substring(0,1))
                                </div>
                            }
                            else
                            {
                                <div class="avatar-circle bg-primary-subtle text-primary" style="width:48px;height:48px;flex-shrink:0;font-size:.9rem;">
                                    @(doc.Name?.Substring(0,1))@(doc.Surname?.Substring(0,1))
                                </div>
                            }
                            <div class="doctor-info">
                                <div class="doctor-name">Dr. @doc.Name @doc.Surname</div>
                                <div class="doctor-branch">@doc.BranchId</div>
                            </div>
                            <div class="doctor-rating">
                                <i class="bi bi-briefcase text-primary" style="font-size:.8rem;"></i>
                                <span>@doc.ExperienceYear il</span>
                            </div>
                        </div>
                    }
                }
                else
                {
                    <div class="text-center text-muted py-4">
                        <i class="bi bi-person-x d-block fs-3 mb-2"></i>
                        Həkim tapılmadı
                    </div>
                }
            </div>
        </div>
    </div>

    <!-- Son Xəstələr -->
    <div class="col-12 col-xl-6">
        <div class="content-card">
            <div class="card-header-custom">
                <h5 class="card-title-custom">
                    <i class="bi bi-person-heart"></i>
                    Son Xəstələr
                </h5>
                <a asp-area="Admin" asp-controller="Patient" asp-action="Index"
                   class="btn btn-sm btn-outline-success rounded-pill px-3">Hamısına bax</a>
            </div>
            @if (Model.RecentPatients.Any())
            {
                <div class="review-list">
                    @foreach (var p in Model.RecentPatients)
                    {
                        var initials = $"{p.Name?.FirstOrDefault()}{p.Surname?.FirstOrDefault()}".Trim();
                        if (string.IsNullOrEmpty(initials)) initials = "?";
                        <div class="review-item">
                            <div class="review-header">
                                <div class="d-flex align-items-center gap-2">
                                    @if (!string.IsNullOrEmpty(p.ImageUrl))
                                    {
                                        <img src="@p.ImageUrl" class="rounded-circle"
                                             style="width:36px;height:36px;object-fit:cover;"
                                             onerror="this.style.display='none'">
                                    }
                                    else
                                    {
                                        <div class="avatar-circle bg-success-subtle text-success sm">@initials</div>
                                    }
                                    <div>
                                        <div class="review-author">@p.FullName</div>
                                        <div class="review-doctor">@p.Email &nbsp;·&nbsp; @(p.Gender ?? "—")</div>
                                    </div>
                                </div>
                                <div>
                                    <span class="badge @(p.Status ? "bg-success-subtle text-success" : "bg-danger-subtle text-danger")" style="font-size:.7rem;">
                                        @(p.Status ? "Aktiv" : "Passiv")
                                    </span>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
            else
            {
                <div class="text-center text-muted py-4">
                    <i class="bi bi-person-x d-block fs-3 mb-2"></i>
                    Xəstə tapılmadı
                </div>
            }
        </div>
    </div>

    <!-- Şöbələr -->
    <div class="col-12 col-xl-6">
        <div class="content-card">
            <div class="card-header-custom">
                <h5 class="card-title-custom">
                    <i class="bi bi-hospital-fill"></i>
                    Şöbələr
                </h5>
                <a asp-area="Admin" asp-controller="Branch" asp-action="Index"
                   class="btn btn-sm btn-outline-warning rounded-pill px-3">Hamısına bax</a>
            </div>
            @if (Model.Branches.Any())
            {
                <div class="activity-feed">
                    @foreach (var b in Model.Branches.Take(5))
                    {
                        <div class="activity-item">
                            <div class="activity-icon" style="background:@(b.ThemeColour ?? "#e0f2fe");color:@(b.ThemeColour ?? "#0284c7");">
                                <i class="bi bi-hospital"></i>
                            </div>
                            <div class="activity-content">
                                <div class="activity-text fw-600">@b.BranchName</div>
                                <div class="activity-time">
                                    <i class="bi bi-person-fill me-1"></i>@b.DoctorCount həkim &nbsp;·&nbsp;
                                    <i class="bi bi-calendar me-1"></i>@b.MonthlyAppointmentCount görüş
                                </div>
                            </div>
                            <div>
                                <span class="badge @(b.Status ? "bg-success-subtle text-success" : "bg-danger-subtle text-danger")" style="font-size:.7rem;">
                                    @(b.Status ? "Aktiv" : "Passiv")
                                </span>
                            </div>
                        </div>
                    }
                </div>
            }
            else
            {
                <div class="text-center text-muted py-4">
                    <i class="bi bi-hospital d-block fs-3 mb-2"></i>
                    Şöbə tapılmadı
                </div>
            }
        </div>
    </div>

</div>
