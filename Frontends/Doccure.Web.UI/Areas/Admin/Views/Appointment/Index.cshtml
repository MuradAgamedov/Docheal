</div>

<!-- Görüş Cədvəli -->
<div class="appt-table-wrap">
    <div class="appt-table-header">
        <h5 class="appt-table-title"><i class="bi bi-list-ul"></i> Görüş Siyahısı</h5>
        <span class="text-muted small">12 görüşdən 1,482 göstərilir</span>
    </div>
    <div style="overflow-x:auto;">
        <table class="appt-table">
            <thead>
                <tr>
                    <th>Görüş ID</th>
                    <th>Xəstə</th>
                    <th>Həkim</th>
                    <th>Şöbə</th>
                    <th>Tarix &amp; Saat</th>
                    <th>Növ</th>
                    <th>Vəziyyət</th>
                    <th style="text-align:center;">Əməliyyat</th>
                </tr>
