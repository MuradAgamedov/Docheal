@section Scripts {
<script>
    function openApptDetail(id, patient, doctor, branch, date, time, type, status, notes) {
        document.getElementById('aModalId').textContent      = id;
        document.getElementById('aModalPatient').textContent = patient;
        document.getElementById('aModalDoctor').textContent  = doctor;
        document.getElementById('aModalBranch').textContent  = branch;
        document.getElementById('aModalDate').textContent    = date;
        document.getElementById('aModalTime').textContent    = time;
        document.getElementById('aModalType').textContent    = type;
        document.getElementById('aModalNotes').textContent   = notes;

        const el = document.getElementById('aModalStatus');
        el.className = 'detail-field-value';
        if      (status === 'Təsdiqləndi')  { el.style.color = '#15803d'; }
        else if (status === 'Gözləyir')     { el.style.color = '#b45309'; }
        else if (status === 'Ləğv edildi')  { el.style.color = '#dc2626'; }
        else                                { el.style.color = '#0e82fd'; }
        el.textContent = status;

        new bootstrap.Modal(document.getElementById('apptDetailModal')).show();
    }

    document.querySelectorAll('.filter-pill').forEach(btn => {
        btn.addEventListener('click', function () {
            document.querySelectorAll('.filter-pill').forEach(b => b.classList.remove('active'));
            this.classList.add('active');
            applyFilters();
        });
    });
    document.getElementById('apptSearch').addEventListener('input', applyFilters);
    document.getElementById('branchFilter').addEventListener('change', applyFilters);
    document.getElementById('statusFilter').addEventListener('change', applyFilters);

    function applyFilters() {
        const search = document.getElementById('apptSearch').value.toLowerCase().trim();
        const branch = document.getElementById('branchFilter').value;
        const status = document.getElementById('statusFilter').value;
        const cat    = (document.querySelector('.filter-pill.active') || {}).dataset?.cat || 'all';

        document.querySelectorAll('#apptTableBody tr').forEach(row => {
            const mSearch = !search || (row.dataset.name || '').includes(search);
            const mBranch = !branch || row.dataset.branch === branch;
            const mStatus = !status || row.dataset.status === status;
            const mCat    = cat === 'all' || row.dataset.cat === cat;
            row.classList.toggle('hidden', !(mSearch && mBranch && mStatus && mCat));
        });
    }
</script>
}
