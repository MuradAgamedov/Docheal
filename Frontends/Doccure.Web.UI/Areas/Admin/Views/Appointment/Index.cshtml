        <option value="tesdiqlendi">Təsdiqləndi</option>
        <option value="gozeliyir">Gözləyir</option>
        <option value="legvedildi">Ləğv edildi</option>
        <option value="tamamlandi">Tamamlandı</option>
    </select>
    <div class="filter-pills">
        <button class="filter-pill active" data-cat="all">Hamısı</button>
        <button class="filter-pill" data-cat="tesdiqlendi">Təsdiqləndi</button>
        <button class="filter-pill" data-cat="gozeliyir">Gözləyir</button>
        <button class="filter-pill" data-cat="legvedildi">Ləğv edildi</button>
