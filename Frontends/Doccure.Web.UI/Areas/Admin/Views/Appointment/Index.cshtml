@model List<Doccure.Web.UI.Dtos.AppointmentDtos.ResultAppointmentDto>
@{
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
    ViewBag.Title = "Görüş İdarəsi";
}

@section Styles {
<style>
    .appt-table-wrapper { background:#fff; border:1px solid #e8edf3; border-radius:16px; box-shadow:0 2px 12px rgba(0,0,0,.04); overflow:hidden; }
    .appt-table thead th { background:#f8fafc; color:#64748b; font-size:.75rem; font-weight:600; text-transform:uppercase; letter-spacing:.5px; padding:14px 20px; border-bottom:1px solid #e8edf3; white-space:nowrap; }
    .appt-table tbody td { padding:14px 20px; vertical-align:middle; font-size:.88rem; color:#374151; border-bottom:1px solid #f1f5f9; }
    .appt-table tbody tr:last-child td { border-bottom:none; }
    .appt-table tbody tr:hover { background:#f8fafc; }
    .appt-id { font-family:monospace; font-size:.8rem; font-weight:600; color:#64748b; }
    .appt-date { font-weight:600; color:#1e293b; }
    .appt-price { font-weight:700; color:#0e82fd; }
    .status-confirmed { background:#d1fae5; color:#065f46; padding:3px 12px; border-radius:50px; font-size:.75rem; font-weight:600; }
    .status-pending { background:#fef3c7; color:#92400e; padding:3px 12px; border-radius:50px; font-size:.75rem; font-weight:600; }
    .status-cancelled { background:#fee2e2; color:#991b1b; padding:3px 12px; border-radius:50px; font-size:.75rem; font-weight:600; }
    .status-completed { background:#dbeafe; color:#1e40af; padding:3px 12px; border-radius:50px; font-size:.75rem; font-weight:600; }
    .table-page-header { display:flex; align-items:center; justify-content:space-between; margin-bottom:24px; gap:12px; flex-wrap:wrap; }
    .page-title-group h2 { font-family:'Poppins',sans-serif; font-size:1.45rem; font-weight:700; color:#1e293b; margin:0; }
    .page-title-group p { color:#94a3b8; font-size:.84rem; margin:4px 0 0 0; }
    .btn-add-primary { background:linear-gradient(135deg,#0e82fd,#5b5cee); color:#fff; border:none; border-radius:10px; padding:10px 22px; font-weight:600; font-size:.88rem; display:inline-flex; align-items:center; gap:8px; text-decoration:none; transition:all .2s; box-shadow:0 4px 12px rgba(14,130,253,.25); }
    .btn-add-primary:hover { transform:translateY(-2px); color:#fff; box-shadow:0 8px 20px rgba(14,130,253,.35); }
    .action-btn { display:inline-flex; align-items:center; justify-content:center; width:34px; height:34px; border-radius:8px; border:none; cursor:pointer; transition:all .2s; text-decoration:none; font-size:.88rem; }
    .action-btn-edit { background:#eff6ff; color:#3b82f6; }
    .action-btn-edit:hover { background:#3b82f6; color:#fff; }
    .action-btn-delete { background:#fff1f2; color:#f43f5e; }
    .action-btn-delete:hover { background:#f43f5e; color:#fff; }
</style>
}

<div class="container-fluid p-4">
    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show rounded-3 border-0 shadow-sm mb-4" role="alert">
            <i class="bi bi-check-circle-fill me-2"></i> @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show rounded-3 border-0 shadow-sm mb-4" role="alert">
            <i class="bi bi-exclamation-triangle-fill me-2"></i> @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="table-page-header">
        <div class="page-title-group">
            <h2><i class="bi bi-calendar-check-fill me-2 text-primary"></i> Görüş İdarəsi</h2>
            <p>Cəmi <strong>@Model?.Count</strong> görüş qeydiyyatda</p>
        </div>
        <a href="@Url.Action("CreateAppointment","Appointment",new{area="Admin"})" class="btn-add-primary">
            <i class="bi bi-plus-lg"></i> Yeni Görüş Əlavə Et
        </a>
    </div>

    <div class="appt-table-wrapper">
        <table class="table appt-table mb-0">
            <thead>
                <tr>
                    <th>#ID</th>
                    <th>Həkim ID</th>
                    <th>Xəstə ID</th>
                    <th>Görüş Tarixi</th>
                    <th>Qiymət</th>
                    <th>Status</th>
                    <th style="width:90px;">Əməliyyat</th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null && Model.Any())
                {
                    foreach (var item in Model)
                    {
                        string statusClass = item.Status switch
                        {
                            "Təsdiqləndi" => "status-confirmed",
                            "Tamamlandı" => "status-completed",
                            "Ləğv edildi" => "status-cancelled",
                            _ => "status-pending"
                        };
                        <tr>
                            <td><span class="appt-id">#GRŞ-@item.AppointmentId.ToString("D4")</span></td>
                            <td class="text-muted">@item.DoctorId</td>
                            <td class="text-muted">@item.PatientId</td>
                            <td><span class="appt-date">@item.AppointmentDate.ToString("dd.MM.yyyy HH:mm")</span></td>
                            <td><span class="appt-price">₼@item.Price.ToString("F2")</span></td>
                            <td><span class="@statusClass">@(string.IsNullOrEmpty(item.Status) ? "Gözləyir" : item.Status)</span></td>
                            <td>
                                <div class="d-flex gap-1">
                                    <a href="@Url.Action("UpdateAppointment","Appointment",new{area="Admin",id=item.AppointmentId})"
                                       class="action-btn action-btn-edit" title="Düzəliş et">
                                        <i class="bi bi-pencil"></i>
                                    </a>
                                    <a href="@Url.Action("DeleteAppointment","Appointment",new{area="Admin",id=item.AppointmentId})"
                                       class="action-btn action-btn-delete" title="Sil"
                                       onclick="return confirm('#@item.AppointmentId nömrəli görüşü silmək istədiyinizdən əminsinizmi?')">
                                        <i class="bi bi-trash"></i>
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="7" class="text-center text-muted py-5">
                            <i class="bi bi-calendar-x" style="font-size:2.5rem; opacity:0.3;"></i>
                            <p class="mt-2">Heç bir görüş qeydiyyatda deyil</p>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
