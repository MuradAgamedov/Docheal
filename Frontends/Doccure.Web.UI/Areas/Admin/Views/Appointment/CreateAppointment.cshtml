@model Doccure.Web.UI.Dtos.AppointmentDtos.CreateAppointmentDto
@{
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
    ViewBag.Title = "Yeni Görüş";
}

@section Styles {
<style>
    .form-card { background:#fff; border:1px solid #e2e8f0; border-radius:16px; padding:2rem; box-shadow:0 4px 12px rgba(0,0,0,.03); }
    .form-section-title { font-family:'Poppins',sans-serif; font-size:.8rem; font-weight:700; text-transform:uppercase; letter-spacing:.8px; color:#94a3b8; margin-bottom:16px; padding-bottom:8px; border-bottom:1px solid #f1f5f9; }
    .form-label { font-family:'Poppins',sans-serif; font-weight:500; font-size:.85rem; color:#334155; margin-bottom:6px; }
    .form-control-custom { width:100%; padding:.65rem 1rem; border:1.5px solid #e2e8f0; border-radius:10px; font-size:.88rem; color:#1e293b; background:#f8fafc; transition:all .2s; outline:none; }
    .form-control-custom:focus { border-color:#0e82fd; background:#fff; box-shadow:0 0 0 3px rgba(14,130,253,.12); }
    .field-validation-error { color:#f43f5e; font-size:.78rem; margin-top:4px; display:block; }
    .btn-submit { background:linear-gradient(135deg,#0e82fd,#5b5cee); color:#fff; border:none; border-radius:10px; padding:.65rem 1.8rem; font-weight:600; font-size:.88rem; transition:all .2s; box-shadow:0 4px 12px rgba(14,130,253,.25); }
    .btn-submit:hover { transform:translateY(-2px); }
    .btn-cancel { background:#f1f5f9; color:#64748b; border:none; border-radius:10px; padding:.65rem 1.5rem; font-weight:500; font-size:.88rem; text-decoration:none; }
    .btn-cancel:hover { background:#e2e8f0; color:#1e293b; }
    .page-back-header { display:flex; align-items:center; gap:12px; margin-bottom:24px; }
    .page-back-header h2 { font-family:'Poppins',sans-serif; font-size:1.35rem; font-weight:700; color:#1e293b; margin:0; }
    .back-link { display:inline-flex; align-items:center; gap:6px; color:#64748b; font-size:.84rem; text-decoration:none; padding:6px 12px; border-radius:8px; background:#f1f5f9; }
    .back-link:hover { background:#e2e8f0; color:#1e293b; }
</style>
}

<div class="container-fluid p-4">
    <div class="page-back-header">
        <a href="@Url.Action("Index","Appointment",new{area="Admin"})" class="back-link">
            <i class="bi bi-arrow-left"></i> Geri
        </a>
        <h2><i class="bi bi-calendar-plus me-2 text-primary"></i> Yeni Görüş Əlavə Et</h2>
    </div>

    <div class="row">
        <div class="col-lg-7">
            <form asp-action="CreateAppointment" asp-controller="Appointment" asp-area="Admin" method="post">
                <div class="form-card mb-4">
                    <p class="form-section-title">Tərəflər</p>
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label asp-for="DoctorId" class="form-label"></label>
                            <input asp-for="DoctorId" class="form-control-custom" placeholder="Həkim ID" />
                            <span asp-validation-for="DoctorId" class="field-validation-error"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="PatientId" class="form-label"></label>
                            <input asp-for="PatientId" class="form-control-custom" placeholder="Xəstə ID" />
                            <span asp-validation-for="PatientId" class="field-validation-error"></span>
                        </div>
                    </div>
                </div>
                <div class="form-card mb-4">
                    <p class="form-section-title">Tarix və Qiymət</p>
                    <div class="row g-3">
                        <div class="col-md-7">
                            <label asp-for="AppointmentDate" class="form-label"></label>
                            <input asp-for="AppointmentDate" type="datetime-local" class="form-control-custom" />
                            <span asp-validation-for="AppointmentDate" class="field-validation-error"></span>
                        </div>
                        <div class="col-md-5">
                            <label asp-for="Price" class="form-label"></label>
                            <input asp-for="Price" type="number" step="0.01" class="form-control-custom" placeholder="0.00" />
                        </div>
                    </div>
                </div>
                <div class="d-flex gap-3">
                    <button type="submit" class="btn-submit"><i class="bi bi-check-lg me-1"></i> Əlavə Et</button>
                    <a href="@Url.Action("Index","Appointment",new{area="Admin"})" class="btn-cancel">Ləğv Et</a>
                </div>
            </form>
        </div>
    </div>
</div>
