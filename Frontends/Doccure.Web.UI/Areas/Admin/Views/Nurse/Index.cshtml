                    <div class="nc-stat-box"><div class="nc-stat-val">890</div><div class="nc-stat-lbl">Xəstə</div></div>
                    <div class="nc-stat-box"><div class="nc-stat-val">4.9<i class="bi bi-star-fill text-warning" style="font-size:.55rem;"></i></div><div class="nc-stat-lbl">Bal</div></div>
                </div>
                <div class="nc-skills">
                    <span class="nc-skill">Triaj</span>
                    <span class="nc-skill">ACLS</span>
                    <span class="nc-skill">Pediatrik Təcili</span>
