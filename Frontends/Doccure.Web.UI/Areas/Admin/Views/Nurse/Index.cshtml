@model List<Doccure.Web.UI.Dtos.NurseDtos.ResultNurseDto>
@{
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
    ViewBag.Title = "Tibb Bacısı İdarəsi";
}

@section Styles {
<style>
    .nurse-card { background:#fff; border:1px solid #e8edf3; border-radius:16px; overflow:hidden; transition:all .3s; box-shadow:0 2px 8px rgba(0,0,0,.03); }
    .nurse-card:hover { transform:translateY(-4px); box-shadow:0 12px 28px rgba(0,0,0,.09); }
    .nc-banner { height:64px; position:relative; }
    .nc-avatar-wrap { position:absolute; bottom:-24px; left:1.1rem; }
    .nc-avatar-ini { width:54px; height:54px; border-radius:50%; border:3px solid #fff; display:flex; align-items:center; justify-content:center; font-family:'Poppins',sans-serif; font-weight:700; font-size:.95rem; color:#fff; box-shadow:0 3px 8px rgba(0,0,0,.12); }
    .nc-body { padding:2rem 1.1rem .85rem; }
    .nc-name { font-family:'Poppins',sans-serif; font-weight:700; font-size:.93rem; color:#1e293b; margin-bottom:2px; }
    .nc-unit { font-size:.73rem; color:#64748b; margin-bottom:.5rem; }
    .status-dot { width:7px; height:7px; border-radius:50%; display:inline-block; margin-right:4px; }
    .dot-active { background:#22c55e; }
    .dot-leave { background:#94a3b8; }
    .dot-break { background:#f59e0b; }
    .nc-stats { display:grid; grid-template-columns:repeat(3,1fr); gap:.35rem; margin:.6rem 0; }
    .nc-stat-box { background:#f8fafc; border-radius:8px; padding:.4rem .2rem; text-align:center; }
    .nc-stat-val { font-weight:700; font-size:.82rem; color:#1e293b; }
    .nc-stat-lbl { font-size:.6rem; color:#94a3b8; }
    .skill-tag { font-size:.63rem; font-weight:600; padding:.15rem .5rem; border-radius:6px; background:#f1f5f9; color:#475569; border:1px solid #e2e8f0; }
    .nc-actions { padding:.65rem 1.1rem; border-top:1px solid #f1f5f9; display:flex; gap:.4rem; }
    .btn-nc-icon { width:32px; height:32px; border-radius:8px; border:1.5px solid #e2e8f0; background:#fff; color:#64748b; display:inline-flex; align-items:center; justify-content:center; font-size:.82rem; cursor:pointer; transition:all .2s; text-decoration:none; }
    .btn-nc-icon:hover { border-color:#0e82fd; color:#0e82fd; background:#eff6ff; }
    .btn-nc-icon.del:hover { border-color:#ef4444; color:#ef4444; background:rgba(239,68,68,.06); }
    .table-page-header { display:flex; align-items:center; justify-content:space-between; margin-bottom:24px; gap:12px; flex-wrap:wrap; }
    .page-title-group h2 { font-family:'Poppins',sans-serif; font-size:1.45rem; font-weight:700; color:#1e293b; margin:0; }
    .page-title-group p { color:#94a3b8; font-size:.84rem; margin:4px 0 0 0; }
    .btn-add-primary { background:linear-gradient(135deg,#0e82fd,#5b5cee); color:#fff; border:none; border-radius:10px; padding:10px 22px; font-weight:600; font-size:.88rem; display:inline-flex; align-items:center; gap:8px; text-decoration:none; transition:all .2s; box-shadow:0 4px 12px rgba(14,130,253,.25); }
    .btn-add-primary:hover { transform:translateY(-2px); color:#fff; }
</style>
}

<div class="container-fluid p-4">
    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show rounded-3 border-0 shadow-sm mb-4">
            <i class="bi bi-check-circle-fill me-2"></i>@TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="table-page-header">
        <div class="page-title-group">
            <h2><i class="bi bi-heart-pulse-fill me-2 text-primary"></i>Tibb Bacısı İdarəsi</h2>
            <p>Cəmi <strong>@Model?.Count</strong> tibb bacısı qeydiyyatda</p>
        </div>
        <a href="@Url.Action("CreateNurse","Nurse",new{area="Admin"})" class="btn-add-primary">
            <i class="bi bi-plus-lg"></i> Yeni Tibb Bacısı
        </a>
    </div>

    @if (Model != null && Model.Any())
    {
        string[] gradients = {
            "linear-gradient(135deg,#ec4899,#f9a8d4)",
            "linear-gradient(135deg,#0e82fd,#38bdf8)",
            "linear-gradient(135deg,#ef4444,#fca5a5)",
            "linear-gradient(135deg,#01c0c8,#6ee7b7)",
            "linear-gradient(135deg,#7c3aed,#c4b5fd)",
            "linear-gradient(135deg,#f59e0b,#fde68a)",
            "linear-gradient(135deg,#16a34a,#86efac)",
            "linear-gradient(135deg,#4f46e5,#a5b4fc)"
        };
        int idx = 0;
        <div class="row g-4">
            @foreach (var item in Model)
            {
                string grad = gradients[idx % gradients.Length];
                idx++;
                string initials = (item.FirstName?.Length > 0 ? item.FirstName[0].ToString() : "") +
                                  (item.LastName?.Length > 0 ? item.LastName[0].ToString() : "");
                string dotClass = item.Status == "Növbədə" ? "dot-active" : item.Status == "Məzuniyyətdə" ? "dot-leave" : "dot-break";
                <div class="col-12 col-md-6 col-xl-3">
                    <div class="nurse-card">
                        <div class="nc-banner" style="background:@grad"></div>
                        <div style="position:relative;margin-top:-24px;padding-left:1.1rem;margin-bottom:.3rem;">
                            <div class="nc-avatar-ini" style="background:@grad">@initials</div>
                        </div>
                        <div class="nc-body" style="padding-top:1.8rem;">
                            <div class="nc-name">T.B. @item.FirstName @item.LastName</div>
                            <div class="nc-unit">@item.Unit · @item.Branch</div>
                            <div class="mb-2" style="font-size:.75rem;">
                                <span class="status-dot @dotClass"></span>
                                <span style="color:#475569;font-weight:600;">@item.Status</span>
                                <span class="ms-2 text-muted">· @item.Shift</span>
                            </div>
                            <div class="nc-stats">
                                <div class="nc-stat-box"><div class="nc-stat-val">@item.Experience</div><div class="nc-stat-lbl">İl Təcrübə</div></div>
                                <div class="nc-stat-box"><div class="nc-stat-val">@item.PatientCount</div><div class="nc-stat-lbl">Xəstə</div></div>
                                <div class="nc-stat-box"><div class="nc-stat-val">@item.Rating<i class="bi bi-star-fill text-warning" style="font-size:.5rem;"></i></div><div class="nc-stat-lbl">Bal</div></div>
                            </div>
                            @if (!string.IsNullOrEmpty(item.Skills))
                            {
                                <div class="d-flex flex-wrap gap-1 mb-2">
                                    @foreach (var skill in item.Skills.Split(',').Take(3))
                                    {
                                        <span class="skill-tag">@skill.Trim()</span>
                                    }
                                </div>
                            }
                            <div class="mb-1">
                                <div class="d-flex justify-content-between" style="font-size:.7rem;">
                                    <span class="text-muted">Performans</span><span class="fw-bold">@item.Performance%</span>
                                </div>
                                <div style="height:5px;background:#f1f5f9;border-radius:10px;overflow:hidden;">
                                    <div style="width:@item.Performance%;height:100%;background:@grad;border-radius:10px;"></div>
                                </div>
                            </div>
                        </div>
                        <div class="nc-actions">
                            <a href="@Url.Action("UpdateNurse","Nurse",new{area="Admin",id=item.NurseId})" class="btn-nc-icon" title="Redaktə et"><i class="bi bi-pencil"></i></a>
                            <a href="@Url.Action("DeleteNurse","Nurse",new{area="Admin",id=item.NurseId})" class="btn-nc-icon del" title="Sil"
                               onclick="return confirm('@item.FirstName @item.LastName adlı tibb bacısını silmək istədiyinizdən əminsinizmi?')">
                                <i class="bi bi-trash"></i>
                            </a>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="text-center py-5 text-muted">
            <i class="bi bi-heart-pulse" style="font-size:3rem;opacity:.3;"></i>
            <p class="mt-3">Heç bir tibb bacısı qeydiyyatda deyil</p>
            <a href="@Url.Action("CreateNurse","Nurse",new{area="Admin"})" class="btn-add-primary d-inline-flex mt-2">
                <i class="bi bi-plus-lg"></i> İlk tibb bacısını əlavə et
            </a>
        </div>
    }
</div>
