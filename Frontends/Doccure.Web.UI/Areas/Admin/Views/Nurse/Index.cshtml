                <button class="btn-nc-icon" title="Redaktə et"><i class="bi bi-pencil"></i></button>
                <button class="btn-nc-icon del" title="Sil"><i class="bi bi-trash"></i></button>
            </div>
        </div>
    </div>

    <!-- 2 -->
    <div class="col-12 col-md-6 col-xl-3 nurse-card-wrap" data-name="mehmet yılmaz" data-cat="cerrahi" data-status="active">
        <div class="nurse-card">
            <div class="nc-banner blue">
                <div class="nc-avatar-wrap">
                    <div class="nc-avatar-ini" style="background:linear-gradient(135deg,#0e82fd,#38bdf8);">MY</div>
                </div>
                <span class="nc-shift-badge shift-night"><i class="bi bi-moon-stars-fill" style="font-size:.6rem;"></i>Gecə</span>
            </div>
            <div class="nc-body">
                <div class="nc-name">T.B. Mehmet Yılmaz</div>
                <div class="nc-unit">Ümumi Cərrahiyyə · Əməliyyat</div>
                <span class="nc-branch-tag" style="background:rgba(79,70,229,.1);color:#4338ca;">Cərrahiyyə</span>
                <div class="nc-status-row">
                    <span class="status-dot dot-active"></span>
                    <span class="nc-status-text st-active">Növbədə</span>
                </div>
                <div class="nc-stats">
                    <div class="nc-stat-box"><div class="nc-stat-val">11</div><div class="nc-stat-lbl">İl Təcrübə</div></div>
                    <div class="nc-stat-box"><div class="nc-stat-val">638</div><div class="nc-stat-lbl">Xəstə</div></div>
                    <div class="nc-stat-box"><div class="nc-stat-val">4.7<i class="bi bi-star-fill text-warning" style="font-size:.55rem;"></i></div><div class="nc-stat-lbl">Bal</div></div>
                </div>
                <div class="nc-skills">
                    <span class="nc-skill">Cərrahiyyə Köm.</span>
                    <span class="nc-skill">Steril Texnika</span>
                    <span class="nc-skill">ACLS</span>
                </div>
                <div class="nc-prog-row">
                    <div class="nc-prog-header"><span class="nc-prog-label">Performans</span><span class="nc-prog-val">88%</span></div>
                    <div class="nc-prog-bar"><div class="nc-prog-fill" style="width:88%;background:linear-gradient(90deg,#0e82fd,#38bdf8);"></div></div>
                </div>
                <div class="nc-prog-row">
                    <div class="nc-prog-header"><span class="nc-prog-label">Davamiyyət</span><span class="nc-prog-val">94%</span></div>
                    <div class="nc-prog-bar"><div class="nc-prog-fill" style="width:94%;background:linear-gradient(90deg,#16a34a,#4ade80);"></div></div>
                </div>
            </div>
            <div class="nc-actions">
                <button class="btn-nc-view"><i class="bi bi-person-lines-fill me-1"></i>Profil</button>
                <button class="btn-nc-icon" title="Redaktə et"><i class="bi bi-pencil"></i></button>
                <button class="btn-nc-icon del" title="Sil"><i class="bi bi-trash"></i></button>
            </div>
        </div>
    </div>

    <!-- 3 -->
    <div class="col-12 col-md-6 col-xl-3 nurse-card-wrap" data-name="fatma demir" data-cat="acil" data-status="active">
        <div class="nurse-card">
            <div class="nc-banner red">
                <div class="nc-avatar-wrap">
                    <img src="https://images.unsplash.com/photo-1582750433449-648ed127bb54?w=100&h=100&fit=crop&crop=face" class="nc-avatar" alt="">
                </div>
                <span class="nc-shift-badge shift-eve"><i class="bi bi-sunset-fill" style="font-size:.6rem;"></i>Axşam</span>
            </div>
            <div class="nc-body">
                <div class="nc-name">T.B. Fatma Demir</div>
