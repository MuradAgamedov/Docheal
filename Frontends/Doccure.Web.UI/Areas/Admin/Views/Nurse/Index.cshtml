                    <div class="nc-prog-header"><span class="nc-prog-label">Performans</span><span class="nc-prog-val">92%</span></div>
                    <div class="nc-prog-bar"><div class="nc-prog-fill" style="width:92%;background:linear-gradient(90deg,#ec4899,#f9a8d4);"></div></div>
                </div>
                <div class="nc-prog-row">
                    <div class="nc-prog-header"><span class="nc-prog-label">Davamiyyət</span><span class="nc-prog-val">97%</span></div>
