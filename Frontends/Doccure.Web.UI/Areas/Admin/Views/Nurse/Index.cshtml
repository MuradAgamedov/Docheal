                <span class="nc-shift-badge shift-day"><i class="bi bi-sun-fill" style="font-size:.6rem;"></i>Gündüz</span>
            </div>
            <div class="nc-body">
                <div class="nc-name">T.B. Ayşe Kaya</div>
                <div class="nc-unit">Daxili Xəstəliklər · Klinik T.Bacısı</div>
                <span class="nc-branch-tag">Daxili</span>
