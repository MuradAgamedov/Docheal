@section Scripts {
<script>
    document.querySelectorAll('.filter-pill').forEach(btn => {
        btn.addEventListener('click', function () {
            document.querySelectorAll('.filter-pill').forEach(b => b.classList.remove('active'));
            this.classList.add('active');
            applyFilters();
        });
    });

    document.getElementById('nurseSearch').addEventListener('input', applyFilters);
    document.getElementById('sortFilter').addEventListener('change', applyFilters);

    function applyFilters() {
        const search = document.getElementById('nurseSearch').value.toLowerCase().trim();
        const cat    = (document.querySelector('.filter-pill.active') || {}).dataset?.cat || 'all';

        document.querySelectorAll('.nurse-card-wrap').forEach(card => {
            const name   = card.dataset.name   || '';
            const ccat   = card.dataset.cat    || '';
            const status = card.dataset.status || '';

            const matchSearch = !search || name.includes(search);
            const matchCat    = cat === 'all' || ccat === cat ||
                                (cat === 'active' && status === 'active') ||
                                (cat === 'leave'  && status === 'leave');

            card.classList.toggle('hidden', !(matchSearch && matchCat));
        });
    }
</script>
}
