                    <div class="nc-stat-box"><div class="nc-stat-val">4.8<i class="bi bi-star-fill text-warning" style="font-size:.55rem;"></i></div><div class="nc-stat-lbl">Bal</div></div>
                </div>
                <div class="nc-skills">
                    <span class="nc-skill">IV Müalicə</span>
                    <span class="nc-skill">Yara Baxımı</span>
