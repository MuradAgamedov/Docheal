                    <div class="nc-prog-header"><span class="nc-prog-label">Performans</span><span class="nc-prog-val">95%</span></div>
                    <div class="nc-prog-bar"><div class="nc-prog-fill" style="width:95%;background:linear-gradient(90deg,#ef4444,#fb923c);"></div></div>
                </div>
                <div class="nc-prog-row">
                    <div class="nc-prog-header"><span class="nc-prog-label">Davamiyyət</span><span class="nc-prog-val">99%</span></div>
                    <div class="nc-prog-bar"><div class="nc-prog-fill" style="width:99%;background:linear-gradient(90deg,#16a34a,#4ade80);"></div></div>
                </div>
            </div>
            <div class="nc-actions">
                <button class="btn-nc-view"><i class="bi bi-person-lines-fill me-1"></i>Profil</button>
                <button class="btn-nc-icon" title="Redaktə et"><i class="bi bi-pencil"></i></button>
                <button class="btn-nc-icon del" title="Sil"><i class="bi bi-trash"></i></button>
            </div>
        </div>
    </div>

    <!-- 4 -->
    <div class="col-12 col-md-6 col-xl-3 nurse-card-wrap" data-name="zeynep arslan" data-cat="dahili" data-status="leave">
        <div class="nurse-card">
