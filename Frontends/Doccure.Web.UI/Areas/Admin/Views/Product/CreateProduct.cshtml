@model Doccure.Web.UI.Dtos.ProductDtos.CreateProductDto
@{
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
    ViewBag.Title = "Yeni Məhsul";
}

@section Styles {
<style>
    .form-card { background:#fff; border:1px solid #e2e8f0; border-radius:16px; padding:2rem; box-shadow:0 4px 12px rgba(0,0,0,.03); }
    .form-section-title { font-family:'Poppins',sans-serif; font-size:.8rem; font-weight:700; text-transform:uppercase; letter-spacing:.8px; color:#94a3b8; margin-bottom:16px; padding-bottom:8px; border-bottom:1px solid #f1f5f9; }
    .form-label { font-family:'Poppins',sans-serif; font-weight:500; font-size:.85rem; color:#334155; margin-bottom:6px; }
    .form-control-custom { width:100%; padding:.65rem 1rem; border:1.5px solid #e2e8f0; border-radius:10px; font-size:.88rem; color:#1e293b; background:#f8fafc; transition:all .2s; outline:none; }
    .form-control-custom:focus { border-color:#22c55e; background:#fff; box-shadow:0 0 0 3px rgba(34,197,94,.12); }
    .form-control-custom.input-validation-error { border-color:#f43f5e; background:#fff5f7; }
    .field-validation-error { color:#f43f5e; font-size:.78rem; margin-top:4px; display:block; }
    .btn-submit { background:linear-gradient(135deg,#22c55e,#16a34a); color:#fff; border:none; border-radius:10px; padding:.65rem 1.8rem; font-weight:600; font-size:.88rem; transition:all .2s; box-shadow:0 4px 12px rgba(22,163,74,.25); }
    .btn-submit:hover { transform:translateY(-2px); box-shadow:0 8px 20px rgba(22,163,74,.35); }
    .btn-cancel { background:#f1f5f9; color:#64748b; border:none; border-radius:10px; padding:.65rem 1.5rem; font-weight:500; font-size:.88rem; text-decoration:none; transition:all .2s; }
    .btn-cancel:hover { background:#e2e8f0; color:#1e293b; }
    .page-back-header { display:flex; align-items:center; gap:12px; margin-bottom:24px; }
    .page-back-header h2 { font-family:'Poppins',sans-serif; font-size:1.35rem; font-weight:700; color:#1e293b; margin:0; }
    .back-link { display:inline-flex; align-items:center; gap:6px; color:#64748b; font-size:.84rem; text-decoration:none; padding:6px 12px; border-radius:8px; background:#f1f5f9; transition:all .2s; }
    .back-link:hover { background:#e2e8f0; color:#1e293b; }
    .toggle-switch { position:relative; display:inline-block; width:48px; height:26px; }
    .toggle-switch input { opacity:0; width:0; height:0; }
    .toggle-slider { position:absolute; cursor:pointer; top:0; left:0; right:0; bottom:0; background:#e2e8f0; border-radius:50px; transition:.3s; }
    .toggle-slider:before { position:absolute; content:""; height:20px; width:20px; left:3px; bottom:3px; background:#fff; border-radius:50%; transition:.3s; box-shadow:0 2px 4px rgba(0,0,0,.15); }
    input:checked + .toggle-slider { background:#22c55e; }
    input:checked + .toggle-slider:before { transform:translateX(22px); }
    .img-upload-box { border:2px dashed #e2e8f0; border-radius:14px; padding:2rem; text-align:center; cursor:pointer; transition:all .2s; background:#f8fafc; position:relative; overflow:hidden; }
    .img-upload-box:hover { border-color:#22c55e; background:#f0fdf4; }
    .img-upload-box i { font-size:2.5rem; color:#cbd5e1; display:block; margin-bottom:.5rem; }
    .img-upload-box span { font-size:.82rem; color:#94a3b8; display:block; }
    .img-upload-box input[type=file] { position:absolute; inset:0; opacity:0; cursor:pointer; width:100%; height:100%; }
    .img-preview-wrap { position:relative; margin-top:.8rem; display:none; }
    .img-preview-wrap img { width:100%; max-height:220px; object-fit:cover; border-radius:10px; }
    .btn-clear-img { position:absolute; top:6px; right:6px; background:rgba(0,0,0,.55); color:#fff; border:none; border-radius:50%; width:28px; height:28px; display:inline-flex; align-items:center; justify-content:center; font-size:.75rem; cursor:pointer; }
</style>
}

<div class="container-fluid p-4">
    <div class="page-back-header">
        <a href="@Url.Action("Index","Product",new{area="Admin"})" class="back-link">
            <i class="bi bi-arrow-left"></i> Geri
        </a>
        <h2><i class="bi bi-plus-circle me-2 text-success"></i>Yeni Məhsul Əlavə Et</h2>
    </div>

    <div class="row">
        <div class="col-lg-8">
            <form asp-action="CreateProduct" asp-controller="Product" asp-area="Admin" method="post" enctype="multipart/form-data">
                <div class="form-card mb-4">
                    <p class="form-section-title">Əsas Məlumatlar</p>
                    <div class="row g-3">
                        <div class="col-md-8">
                            <label asp-for="ProductName" class="form-label"></label>
                            <input asp-for="ProductName" class="form-control-custom" placeholder="Məs: Panadol 500mg" />
                            <span asp-validation-for="ProductName" class="field-validation-error"></span>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="Price" class="form-label"></label>
                            <input asp-for="Price" type="number" step="0.01" min="0" class="form-control-custom" placeholder="0.00" />
                            <span asp-validation-for="Price" class="field-validation-error"></span>
                        </div>
                        <div class="col-12">
                            <label asp-for="Category" class="form-label"></label>
                            <input asp-for="Category" class="form-control-custom" placeholder="Məs: Ağrıkəsici, Vitamin, Antibiotik..." />
                            <span asp-validation-for="Category" class="field-validation-error"></span>
                        </div>
                    </div>
                </div>

                <div class="form-card mb-4">
                    <p class="form-section-title">Şəkil</p>
                    <div class="img-upload-box" id="uploadBox">
                        <i class="bi bi-cloud-upload"></i>
                        <span><strong>Şəkil seçin</strong> və ya buraya sürükləyin</span>
                        <span class="mt-1">JPG, PNG, WEBP (maks 5MB)</span>
                        <input type="file" name="imageFile" id="imageFileInput" accept="image/*" />
                    </div>
                    <div class="img-preview-wrap" id="previewWrap">
                        <img id="imgPreview" src="#" alt="Önizləmə" />
                        <button type="button" class="btn-clear-img" id="clearImg"><i class="bi bi-x"></i></button>
                    </div>
                </div>

                <div class="form-card mb-4">
                    <p class="form-section-title">Status</p>
                    <div class="d-flex align-items-center gap-3">
                        <label class="toggle-switch">
                            <input asp-for="Status" type="checkbox" checked />
                            <span class="toggle-slider"></span>
                        </label>
                        <span class="text-muted" style="font-size:.85rem;">Aktivdir (mağazada görünür)</span>
                    </div>
                </div>

                <div class="d-flex gap-3">
                    <button type="submit" class="btn-submit"><i class="bi bi-check-lg me-1"></i>Əlavə Et</button>
                    <a href="@Url.Action("Index","Product",new{area="Admin"})" class="btn-cancel">Ləğv Et</a>
                </div>
            </form>
        </div>

        <div class="col-lg-4">
            <div class="form-card">
                <p class="form-section-title">Məlumat</p>
                <div class="d-flex gap-2 mb-3">
                    <i class="bi bi-info-circle text-success mt-1"></i>
                    <p class="text-muted small mb-0">Əlavə etdiyiniz məhsul dərhal istifadəçilərin mağaza səhifəsində görünəcək.</p>
                </div>
                <div class="d-flex gap-2">
                    <i class="bi bi-eye text-primary mt-1"></i>
                    <p class="text-muted small mb-0">Status "Aktiv" olarsa məhsul mağazada göstərilir, "Deaktiv" olarsa gizlədilir.</p>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
    const fileInput = document.getElementById('imageFileInput');
    const previewWrap = document.getElementById('previewWrap');
    const imgPreview = document.getElementById('imgPreview');
    const clearBtn = document.getElementById('clearImg');
    const uploadBox = document.getElementById('uploadBox');

    fileInput.addEventListener('change', function () {
        if (this.files && this.files[0]) {
            const reader = new FileReader();
            reader.onload = e => {
                imgPreview.src = e.target.result;
                previewWrap.style.display = 'block';
                uploadBox.style.borderColor = '#22c55e';
                uploadBox.querySelectorAll('span')[0].textContent = this.files[0].name;
            };
            reader.readAsDataURL(this.files[0]);
        }
    });

    clearBtn.addEventListener('click', function () {
        fileInput.value = '';
        imgPreview.src = '#';
        previewWrap.style.display = 'none';
        uploadBox.style.borderColor = '';
        uploadBox.querySelectorAll('span')[0].innerHTML = '<strong>Şəkil seçin</strong> və ya buraya sürükləyin';
    });
</script>
}
