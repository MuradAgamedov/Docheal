                </div>
                <span class="dc-status-badge dc-status-available"><i class="bi bi-circle-fill me-1" style="font-size:.5rem;"></i>Mövcud</span>
            </div>
            <div class="dc-body">
                <div class="dc-name">Dr. Murat Demir</div>
                <div class="dc-specialty">Kardioloq · Daxili Tibb</div>
                <span class="dc-branch-tag">Kardiologiya</span>
                <div class="dc-rating">
                    <span class="dc-stars">★★★★★</span>
                    <span class="dc-rating-val">4.9</span>
                    <span class="dc-review-cnt">(218 rəy)</span>
                </div>
                <div class="dc-stats">
                    <div class="dc-stat-box"><div class="dc-stat-val">14</div><div class="dc-stat-lbl">İl Təcrübə</div></div>
                    <div class="dc-stat-box"><div class="dc-stat-val">2.4K</div><div class="dc-stat-lbl">Görüş</div></div>
                    <div class="dc-stat-box"><div class="dc-stat-val">1.8K</div><div class="dc-stat-lbl">Xəstə</div></div>
                </div>
                <div class="dc-slots-label"><i class="bi bi-clock me-1"></i>Bu Günkü Mövcud Saatlar</div>
