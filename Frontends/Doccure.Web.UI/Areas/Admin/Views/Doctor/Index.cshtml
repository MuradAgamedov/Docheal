@section Scripts {
<script>
    document.querySelectorAll('.filter-pill').forEach(btn => {
        btn.addEventListener('click', function () {
            document.querySelectorAll('.filter-pill').forEach(b => b.classList.remove('active'));
            this.classList.add('active');
            applyFilters();
        });
    });

    ['doctorSearch', 'branchFilter', 'statusFilter'].forEach(id => {
        const el = document.getElementById(id);
        if (el) el.addEventListener('input', applyFilters);
    });

    function applyFilters() {
        const search  = document.getElementById('doctorSearch').value.toLowerCase().trim();
        const branch  = document.getElementById('branchFilter').value.toLowerCase();
        const status  = document.getElementById('statusFilter').value.toLowerCase();
        const cat     = (document.querySelector('.filter-pill.active') || {}).dataset?.cat || 'all';

        document.querySelectorAll('.doctor-card-wrap').forEach(card => {
            const name    = card.dataset.name   || '';
            const cbranch = card.dataset.branch || '';
            const cstatus = card.dataset.status || '';
            const ccat    = card.dataset.cat    || '';

            const matchSearch = !search || name.includes(search);
            const matchBranch = !branch || cbranch === branch;
            const matchStatus = !status || cstatus === status;
            const matchCat    = cat === 'all' || ccat === cat ||
                                (cat === 'available' && cstatus === 'available') ||
                                (cat === 'busy'      && cstatus === 'busy');

            card.classList.toggle('hidden', !(matchSearch && matchBranch && matchStatus && matchCat));
        });
    }
</script>
}
