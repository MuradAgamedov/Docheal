    <!-- 4: Dr. Zeynep Çelik -->
    <div class="col-12 col-md-6 col-xl-4 col-xxl-3 doctor-card-wrap"
         data-name="zeynep çelik" data-branch="nevrologiya" data-cat="dahili" data-status="busy">
