@model List<Doccure.Web.UI.Dtos.MedicineDtos.ResultMedicineDto>
@{
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
    ViewBag.Title = "Dərmanlar";
}

@section Styles {
<style>
    .medicine-table-wrapper {
        background: #fff;
        border-radius: 16px;
        border: 1px solid #e8edf3;
        box-shadow: 0 2px 12px rgba(0,0,0,0.04);
        overflow: hidden;
    }
    .medicine-table thead th {
        background: #f8fafc;
        color: #64748b;
        font-size: 0.75rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        padding: 14px 20px;
        border-bottom: 1px solid #e8edf3;
        white-space: nowrap;
    }
    .medicine-table tbody td {
        padding: 14px 20px;
        vertical-align: middle;
        font-size: 0.88rem;
        color: #374151;
        border-bottom: 1px solid #f1f5f9;
    }
    .medicine-table tbody tr:last-child td { border-bottom: none; }
    .medicine-table tbody tr:hover { background: #f8fafc; }
    .medicine-name {
        font-weight: 600;
        color: #1e293b;
        font-size: 0.93rem;
    }
    .barcode-badge {
        display: inline-flex;
        align-items: center;
        gap: 5px;
        background: #f1f5f9;
        color: #475569;
        font-size: 0.75rem;
        font-weight: 600;
        padding: 3px 10px;
        border-radius: 8px;
        font-family: monospace;
    }
    .stock-ok { color: #059669; font-weight: 600; }
    .stock-critical { color: #dc2626; font-weight: 600; }
    .stock-warning { color: #d97706; font-weight: 600; }
    .pill-active {
        display: inline-block;
        padding: 3px 12px;
        border-radius: 50px;
        font-size: 0.75rem;
        font-weight: 600;
        background: #d1fae5;
        color: #065f46;
    }
    .pill-inactive {
        display: inline-block;
        padding: 3px 12px;
        border-radius: 50px;
        font-size: 0.75rem;
        font-weight: 600;
        background: #fee2e2;
        color: #991b1b;
    }
    .table-page-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 24px;
        gap: 12px;
        flex-wrap: wrap;
    }
    .page-title-group h2 {
        font-family: 'Poppins', sans-serif;
        font-size: 1.45rem;
        font-weight: 700;
        color: #1e293b;
        margin: 0;
    }
    .page-title-group p {
        color: #94a3b8;
        font-size: 0.84rem;
        margin: 4px 0 0 0;
    }
    .btn-add-primary {
        background: linear-gradient(135deg, #0e82fd, #5b5cee);
        color: #fff;
        border: none;
        border-radius: 10px;
        padding: 10px 22px;
        font-weight: 600;
        font-size: 0.88rem;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        text-decoration: none;
        transition: all 0.2s;
        box-shadow: 0 4px 12px rgba(14,130,253,0.25);
    }
    .btn-add-primary:hover {
        transform: translateY(-2px);
        box-shadow: 0 8px 20px rgba(14,130,253,0.35);
        color: #fff;
    }
    .action-btn {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 34px;
        height: 34px;
        border-radius: 8px;
        border: none;
        cursor: pointer;
        transition: all 0.2s;
        text-decoration: none;
        font-size: 0.88rem;
    }
    .action-btn-edit { background: #eff6ff; color: #3b82f6; }
    .action-btn-edit:hover { background: #3b82f6; color: #fff; }
    .action-btn-delete { background: #fff1f2; color: #f43f5e; }
    .action-btn-delete:hover { background: #f43f5e; color: #fff; }
    .exp-warning { color: #dc2626; font-weight: 600; }
    .exp-ok { color: #374151; }
    .price-cell { font-weight: 700; color: #0e82fd; }
</style>
}

<div class="container-fluid p-4">
    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show rounded-3 border-0 shadow-sm mb-4" role="alert">
            <i class="bi bi-check-circle-fill me-2"></i> @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show rounded-3 border-0 shadow-sm mb-4" role="alert">
            <i class="bi bi-exclamation-triangle-fill me-2"></i> @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="table-page-header">
        <div class="page-title-group">
            <h2><i class="bi bi-capsule me-2 text-primary"></i> Dərman Anbarı</h2>
            <p>Cəmi <strong>@Model?.Count</strong> dərman qeydiyyatda</p>
        </div>
        <a href="@Url.Action("CreateMedicine","Medicine",new{area="Admin"})" class="btn-add-primary">
            <i class="bi bi-plus-lg"></i> Yeni Dərman Əlavə Et
        </a>
    </div>

    <div class="medicine-table-wrapper">
        <table class="table medicine-table mb-0">
            <thead>
                <tr>
                    <th>#</th>
                    <th>Dərman Adı</th>
                    <th>Barkod</th>
                    <th>Stok</th>
                    <th>Kritik Stok</th>
                    <th>Qiymət</th>
                    <th>Son İst. Tarixi</th>
                    <th>Status</th>
                    <th style="width:90px;">Əməliyyat</th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null && Model.Any())
                {
                    int i = 1;
                    foreach (var item in Model)
                    {
                        string stockClass = item.Stock == 0 ? "stock-critical" : (item.Stock <= item.CriticalStockLevel ? "stock-warning" : "stock-ok");
                        bool isExpiringSoon = item.ExpirationDate <= DateTime.Now.AddMonths(3);
                        <tr>
                            <td class="text-muted">@i</td>
                            <td><span class="medicine-name">@item.MedicineName</span></td>
                            <td><span class="barcode-badge"><i class="bi bi-upc-scan"></i>@item.Barcode</span></td>
                            <td><span class="@stockClass">@item.Stock ədəd</span></td>
                            <td class="text-muted">@item.CriticalStockLevel ədəd</td>
                            <td><span class="price-cell">₼@item.UnitPrice.ToString("F2")</span></td>
                            <td>
                                <span class="@(isExpiringSoon ? "exp-warning" : "exp-ok")">
                                    @(isExpiringSoon ? "⚠ " : "")@item.ExpirationDate.ToString("dd.MM.yyyy")
                                </span>
                            </td>
                            <td>
                                @if (item.Status)
                                {
                                    <span class="pill-active">Aktiv</span>
                                }
                                else
                                {
                                    <span class="pill-inactive">Deaktiv</span>
                                }
                            </td>
                            <td>
                                <div class="d-flex gap-1">
                                    <a href="@Url.Action("UpdateMedicine","Medicine",new{area="Admin",id=item.MedicineId})" 
                                       class="action-btn action-btn-edit" title="Düzəliş et">
                                        <i class="bi bi-pencil"></i>
                                    </a>
                                    <a href="@Url.Action("DeleteMedicine","Medicine",new{area="Admin",id=item.MedicineId})"
                                       class="action-btn action-btn-delete" title="Sil"
                                       onclick="return confirm('@item.MedicineName dərmanını silmək istədiyinizdən əminsinizmi?')">
                                        <i class="bi bi-trash"></i>
                                    </a>
                                </div>
                            </td>
                        </tr>
                        i++;
                    }
                }
                else
                {
                    <tr>
                        <td colspan="9" class="text-center text-muted py-5">
                            <i class="bi bi-capsule" style="font-size:2.5rem; opacity:0.3;"></i>
                            <p class="mt-2">Heç bir dərman qeydiyyatda deyil</p>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
