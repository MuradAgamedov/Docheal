@section Scripts {
<script>
    const bgMap = {
        'AK':  'linear-gradient(135deg,#ec4899,#f9a8d4)',
        'ME':  'linear-gradient(135deg,#0e82fd,#38bdf8)',
        'FY':  'linear-gradient(135deg,#f59e0b,#fde68a)',
        'HB':  'linear-gradient(135deg,#ef4444,#fca5a5)',
        'NŞ':  'linear-gradient(135deg,#7c3aed,#c4b5fd)',
        'EY':  'linear-gradient(135deg,#01c0c8,#6ee7b7)',
        'SA':  'linear-gradient(135deg,#ec4899,#f9a8d4)',
        'KÖ':  'linear-gradient(135deg,#16a34a,#86efac)',
        'ZÇ':  'linear-gradient(135deg,#94a3b8,#cbd5e1)',
        'AK2': 'linear-gradient(135deg,#dc2626,#fca5a5)',
    };

    function openDetail(ini, name, id, age, gender, blood, branch, doctor, phone, email, lastVisit, status) {
        const disp = ini.replace('2','');
        document.getElementById('modalAvatar').textContent = disp;
        document.getElementById('modalAvatar').style.background = bgMap[ini] || 'linear-gradient(135deg,#0e82fd,#38bdf8)';
        document.getElementById('modalName').textContent      = name;
        document.getElementById('modalId').textContent        = id;
        document.getElementById('modalAge').textContent       = age;
        document.getElementById('modalGender').textContent    = gender;
        document.getElementById('modalBlood').textContent     = blood;
        document.getElementById('modalBranch').textContent    = branch;
        document.getElementById('modalDoctor').textContent    = doctor;
        document.getElementById('modalPhone').textContent     = phone;
        document.getElementById('modalEmail').textContent     = email;
        document.getElementById('modalLastVisit').textContent = lastVisit;

        const el = document.getElementById('modalStatus');
        el.className = 'badge-status mt-2';
        const dot = '<i class="bi bi-circle-fill" style="font-size:.45rem;"></i>';
        if (status === 'Aktiv')        { el.classList.add('bs-active');   el.innerHTML = dot + 'Aktiv'; }
        else if (status === 'Yeni')    { el.classList.add('bs-new');      el.innerHTML = dot + 'Yeni'; }
        else if (status === 'Kritik')  { el.classList.add('bs-critical'); el.innerHTML = dot + 'Kritik'; }
        else                           { el.classList.add('bs-passive');  el.innerHTML = dot + 'Passiv'; }

        new bootstrap.Modal(document.getElementById('patientDetailModal')).show();
    }

    document.querySelectorAll('.filter-pill').forEach(btn => {
        btn.addEventListener('click', function () {
            document.querySelectorAll('.filter-pill').forEach(b => b.classList.remove('active'));
            this.classList.add('active');
            applyFilters();
        });
    });
    document.getElementById('patientSearch').addEventListener('input', applyFilters);
    document.getElementById('branchFilter').addEventListener('change', applyFilters);
    document.getElementById('statusFilter').addEventListener('change', applyFilters);

    function applyFilters() {
        const search  = document.getElementById('patientSearch').value.toLowerCase().trim();
        const branch  = document.getElementById('branchFilter').value;
        const status  = document.getElementById('statusFilter').value;
        const cat     = (document.querySelector('.filter-pill.active') || {}).dataset?.cat || 'all';

        document.querySelectorAll('#patientTableBody tr').forEach(row => {
            const mSearch = !search || (row.dataset.name || '').includes(search);
            const mBranch = !branch || row.dataset.branch === branch;
            const mStatus = !status || row.dataset.status === status;
            const mCat    = cat === 'all' || row.dataset.cat === cat;
            row.classList.toggle('hidden', !(mSearch && mBranch && mStatus && mCat));
        });
    }
</script>
}
