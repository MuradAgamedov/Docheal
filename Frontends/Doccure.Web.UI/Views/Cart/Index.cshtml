@model List<Doccure.Web.UI.Dtos.CartDtos.CartItemDto>
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewBag.Title = "Səbət";
    var total = Model.Sum(x => x.TotalPrice);
    var count = Model.Sum(x => x.Quantity);
}

@section Styles {
<style>
    .cart-hero { background:linear-gradient(135deg,#15803d,#22c55e); padding:2.5rem 0; color:#fff; margin-bottom:2rem; }
    .cart-hero h1 { font-family:'Poppins',sans-serif; font-size:1.9rem; font-weight:800; margin:0; }
    .cart-wrapper { padding:0 0 4rem; background:#f0fdf4; min-height:60vh; }
    .cart-table-card { background:#fff; border-radius:18px; border:1px solid #dcfce7; box-shadow:0 2px 12px rgba(22,163,74,.06); overflow:hidden; }
    .cart-table thead th { background:#f0fdf4; color:#15803d; font-size:.75rem; font-weight:700; text-transform:uppercase; letter-spacing:.5px; padding:14px 20px; border-bottom:2px solid #dcfce7; }
    .cart-table tbody td { padding:16px 20px; vertical-align:middle; border-bottom:1px solid #f0fdf4; }
    .cart-table tbody tr:last-child td { border-bottom:none; }
    .product-thumb { width:56px; height:56px; border-radius:12px; background:#dcfce7; display:inline-flex; align-items:center; justify-content:center; color:#16a34a; font-size:1.6rem; flex-shrink:0; overflow:hidden; }
    .product-thumb img { width:100%; height:100%; object-fit:cover; }
    .item-price { font-weight:700; color:#16a34a; font-size:.95rem; }
    .btn-remove { background:#fff1f2; color:#f43f5e; border:none; border-radius:8px; width:32px; height:32px; display:inline-flex; align-items:center; justify-content:center; cursor:pointer; transition:all .2s; }
    .btn-remove:hover { background:#f43f5e; color:#fff; }
    .summary-card { background:#fff; border-radius:18px; border:1px solid #dcfce7; box-shadow:0 2px 12px rgba(22,163,74,.06); padding:1.5rem; position:sticky; top:80px; }
    .summary-title { font-family:'Poppins',sans-serif; font-weight:700; font-size:1.05rem; color:#1e293b; margin-bottom:1.2rem; }
    .summary-row { display:flex; justify-content:space-between; align-items:center; padding:.55rem 0; font-size:.88rem; }
    .summary-row.total { border-top:2px dashed #dcfce7; margin-top:.5rem; padding-top:.9rem; font-weight:800; font-size:1rem; color:#16a34a; }
    .btn-checkout { width:100%; background:linear-gradient(135deg,#16a34a,#22c55e); color:#fff; border:none; border-radius:14px; padding:.85rem; font-weight:700; font-size:.95rem; margin-top:1.2rem; cursor:pointer; transition:all .2s; box-shadow:0 4px 16px rgba(22,163,74,.3); }
    .btn-checkout:hover { transform:translateY(-2px); box-shadow:0 8px 24px rgba(22,163,74,.4); }
    .btn-continue { display:block; text-align:center; margin-top:.75rem; color:#16a34a; font-size:.85rem; font-weight:600; text-decoration:none; }
    .btn-continue:hover { color:#15803d; }
    .empty-cart { text-align:center; padding:5rem 0; }
    .empty-cart i { font-size:5rem; color:#bbf7d0; display:block; margin-bottom:1rem; }
    .btn-clear { background:#fff1f2; color:#f43f5e; border:none; border-radius:10px; padding:.45rem 1rem; font-size:.82rem; font-weight:600; cursor:pointer; transition:all .2s; }
    .btn-clear:hover { background:#f43f5e; color:#fff; }
</style>
}

<div class="cart-hero">
    <div class="container">
        <div class="d-flex align-items-center gap-3">
            <a href="@Url.Action("Index","Shop")" class="text-white text-decoration-none opacity-75">
                <i class="bi bi-arrow-left me-1"></i> Mağazaya qayıt
            </a>
            <span class="text-white opacity-50">|</span>
            <h1><i class="bi bi-cart2 me-2"></i>Mənim Səbətim</h1>
        </div>
    </div>
</div>

<div class="cart-wrapper">
    <div class="container">
        <div class="row g-4">
            <div class="col-lg-8">
                @if (!Model.Any())
                {
                    <div class="cart-table-card">
                        <div class="empty-cart">
                            <i class="bi bi-cart-x"></i>
                            <h5 style="color:#1e293b;font-family:'Poppins',sans-serif;">Səbətiniz boşdur</h5>
                            <p class="text-muted">Mağazadan məhsul əlavə edin</p>
                            <a href="@Url.Action("Index","Shop")" class="btn btn-success rounded-pill px-4 mt-2">Mağazaya keç</a>
                        </div>
                    </div>
                }
                else
                {
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <span class="text-muted" style="font-size:.85rem;"><strong>@count</strong> ədəd məhsul</span>
                        <form asp-action="ClearCart" asp-controller="Cart" method="post">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn-clear" onclick="return confirm('Səbəti tamamilə təmizləmək istəyirsiniz?')">
                                <i class="bi bi-trash me-1"></i>Səbəti Təmizlə
                            </button>
                        </form>
                    </div>
                    <div class="cart-table-card">
                        <table class="table cart-table mb-0">
                            <thead>
                                <tr>
                                    <th>Məhsul</th>
                                    <th>Qiymət</th>
                                    <th>Miqdar</th>
                                    <th>Cəm</th>
                                    <th></th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in Model)
                                {
                                    <tr>
                                        <td>
                                            <div class="d-flex align-items-center gap-3">
                                                <div class="product-thumb">
                                                    @if (!string.IsNullOrEmpty(item.ImageUrl))
                                                    {
                                                        <img src="@item.ImageUrl" alt="@item.ProductName"
                                                             onerror="this.parentElement.innerHTML='<i class=\'bi bi-bag\'></i>';" />
                                                    }
                                                    else
                                                    {
                                                        <i class="bi bi-bag"></i>
                                                    }
                                                </div>
                                                <div>
                                                    <div style="font-weight:600;font-size:.88rem;color:#1e293b;">@item.ProductName</div>
                                                    <div style="font-size:.72rem;color:#94a3b8;">Kod: #@item.ProductId</div>
                                                </div>
                                            </div>
                                        </td>
                                        <td class="item-price">₼@item.Price.ToString("F2")</td>
                                        <td>
                                            <span style="background:#f0fdf4;border-radius:30px;padding:4px 14px;font-weight:700;font-size:.9rem;color:#16a34a;">
                                                @item.Quantity
                                            </span>
                                        </td>
                                        <td class="item-price">₼@item.TotalPrice.ToString("F2")</td>
                                        <td>
                                            <form asp-action="RemoveItem" asp-controller="Cart" method="post" style="display:inline;">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="productId" value="@item.ProductId" />
                                                <button type="submit" class="btn-remove" title="Sil">
                                                    <i class="bi bi-trash"></i>
                                                </button>
                                            </form>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>

            <div class="col-lg-4">
                <div class="summary-card">
                    <div class="summary-title"><i class="bi bi-receipt me-2 text-success"></i>Sifariş Xülasəsi</div>
                    <div class="summary-row">
                        <span class="text-muted">Məhsullar</span>
                        <span>@count ədəd</span>
                    </div>
                    <div class="summary-row">
                        <span class="text-muted">Ara cəm</span>
                        <span>₼@total.ToString("F2")</span>
                    </div>
                    <div class="summary-row">
                        <span class="text-muted">Çatdırılma</span>
                        <span class="text-success fw-semibold">Pulsuz</span>
                    </div>
                    <div class="summary-row total">
                        <span>Ümumi</span>
                        <span>₼@total.ToString("F2")</span>
                    </div>
                    @if (Model.Any())
                    {
                        <button class="btn-checkout" onclick="alert('Bu funksiya tezliklə əlavə olunacaq!')">
                            <i class="bi bi-bag-check me-2"></i>Sifarişi Tamamla
                        </button>
                    }
                    <a href="@Url.Action("Index","Shop")" class="btn-continue">
                        <i class="bi bi-arrow-left me-1"></i> Alışverişə davam et
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>
