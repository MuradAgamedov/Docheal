@model LoginViewModel
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="az">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Daxil Ol – Doccure</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Poppins:wght@600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <style>
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
        .field-validation-valid { display: none !important; }

        body {
            font-family: 'Inter', sans-serif;
            min-height: 100vh;
            background: linear-gradient(135deg, #0e82fd 0%, #01c0c8 100%);
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 2rem 1rem;
        }

        .login-wrapper {
            width: 100%;
            max-width: 460px;
        }

        .login-card {
            background: #fff;
            border-radius: 24px;
            box-shadow: 0 24px 64px rgba(14,130,253,.18);
            overflow: hidden;
        }

        .login-header {
            background: linear-gradient(135deg, #0e82fd, #01c0c8);
            padding: 2.2rem 2rem 1.8rem;
            text-align: center;
            color: #fff;
        }

        .login-logo {
            display: inline-flex;
            align-items: center;
            gap: 10px;
            margin-bottom: 0.8rem;
        }

        .login-logo-icon {
            width: 44px;
            height: 44px;
            background: rgba(255,255,255,.2);
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.4rem;
        }

        .login-logo-text {
            font-family: 'Poppins', sans-serif;
            font-weight: 700;
            font-size: 1.5rem;
            letter-spacing: -.3px;
        }

        .login-header h2 {
            font-family: 'Poppins', sans-serif;
            font-weight: 700;
            font-size: 1.25rem;
            margin-bottom: 4px;
        }

        .login-header p {
            font-size: .87rem;
            opacity: .85;
            margin: 0;
        }

        .login-body {
            padding: 2.2rem 2rem;
        }

        .form-label {
            font-size: .82rem;
            font-weight: 600;
            color: #374151;
            margin-bottom: 6px;
        }

        .form-label span { color: #ef4444; }

        .input-group-custom {
            position: relative;
            display: flex;
            align-items: center;
        }

        .input-group-custom .input-icon {
            position: absolute;
            left: .95rem;
            color: #94a3b8;
            font-size: 1.05rem;
            pointer-events: none;
            transition: color .2s;
        }

        .form-control-custom {
            width: 100%;
            padding: .68rem 1rem .68rem 2.6rem;
            border: 1.5px solid #e2e8f0;
            border-radius: 10px;
            font-size: .88rem;
            color: #1e293b;
            background: #f8fafc;
            transition: all .2s ease;
            outline: none;
        }

        .form-control-custom::placeholder { color: #94a3b8; }

        .form-control-custom:focus {
            border-color: #0e82fd;
            background: #fff;
            box-shadow: 0 0 0 3px rgba(14,130,253,.12);
        }

        .form-control-custom:focus + .input-icon {
            color: #0e82fd;
        }

        .form-control-custom.is-invalid {
            border-color: #ef4444;
            background: #fff;
        }

        .form-control-custom.is-invalid:focus {
            box-shadow: 0 0 0 3px rgba(239,68,68,.12);
        }

        .toggle-pw {
            position: absolute;
            right: .9rem;
            top: 50%;
            transform: translateY(-50%);
            color: #94a3b8;
            cursor: pointer;
            font-size: .95rem;
            z-index: 2;
            background: none;
            border: none;
            padding: 0;
        }

        .toggle-pw:hover { color: #0e82fd; }

        .field-error {
            font-size: .75rem;
            color: #ef4444;
            margin-top: 4px;
            display: none;
            align-items: center;
            gap: 4px;
        }

        .field-error.field-validation-error {
            display: flex;
        }

        .field-error.field-validation-error::before {
            content: "\f33a"; /* bi-exclamation-circle-fill unicode */
            font-family: "bootstrap-icons";
            font-size: .85rem;
            display: inline-block;
        }

        .remember-forgot {
            display: flex;
            align-items: center;
            justify-content: space-between;
            font-size: 0.82rem;
            margin-top: 0.5rem;
            margin-bottom: 1.5rem;
        }

        .checkbox-custom {
            display: flex;
            align-items: center;
            gap: 6px;
            cursor: pointer;
            color: #64748b;
        }

        .checkbox-custom input {
            cursor: pointer;
            width: 15px;
            height: 15px;
            border-radius: 4px;
            border: 1.5px solid #cbd5e1;
            accent-color: #0e82fd;
        }

        .forgot-link {
            color: #0e82fd;
            font-weight: 500;
            text-decoration: none;
        }

        .forgot-link:hover {
            text-decoration: underline;
        }

        .btn-login {
            width: 100%;
            padding: .75rem;
            background: linear-gradient(135deg, #0e82fd, #01c0c8);
            color: #fff;
            border: none;
            border-radius: 10px;
            font-family: 'Poppins', sans-serif;
            font-weight: 600;
            font-size: .95rem;
            cursor: pointer;
            transition: all .25s;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
        }

        .btn-login:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 20px rgba(14,130,253,.35);
        }

        .btn-login:active { transform: translateY(0); }

        .login-footer {
            text-align: center;
            margin-top: 1.4rem;
            font-size: .84rem;
            color: #64748b;
        }

        .login-footer a {
            color: #0e82fd;
            font-weight: 600;
            text-decoration: none;
        }

        .login-footer a:hover { text-decoration: underline; }

        /* Toast notifications styling */
        .toast-container {
            position: fixed !important;
            top: 20px !important;
            right: 20px !important;
            z-index: 999999 !important;
            display: flex;
            flex-direction: column;
            gap: 10px;
            pointer-events: none;
        }

        .toast-item {
            background: rgba(255, 255, 255, 0.95);
            backdrop-filter: blur(10px);
            border-left: 5px solid #22c55e;
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.08);
            border-radius: 12px;
            padding: 1rem 1.25rem;
            min-width: 300px;
            max-width: 400px;
            display: flex;
            align-items: center;
            gap: 12px;
            transform: translateX(120%);
            transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
            pointer-events: auto;
        }

        .toast-item.show {
            transform: translateX(0);
        }

        .toast-item.hide {
            transform: translateX(120%);
            opacity: 0;
        }

        .toast-icon {
            font-size: 1.25rem;
            flex-shrink: 0;
        }

        .toast-success {
            border-left-color: #22c55e;
        }
        .toast-success .toast-icon {
            color: #22c55e;
        }

        .toast-error {
            border-left-color: #ef4444;
        }
        .toast-error .toast-icon {
            color: #ef4444;
        }

        .toast-message {
            font-size: 0.85rem;
            font-weight: 600;
            color: #1e293b;
            line-height: 1.4;
        }
    </style>
</head>
<body>

    <div class="login-wrapper">
        <div class="login-card">
            
            <div class="login-header">
                <div class="login-logo">
                    <div class="login-logo-icon">
                        <i class="bi bi-hospital"></i>
                    </div>
                    <span class="login-logo-text">Doccure</span>
                </div>
                <h2>Xoş Gəlmisiniz</h2>
                <p>Hesabınıza daxil olmaq üçün məlumatlarınızı yazın.</p>
            </div>

            <div class="login-body">
                <form method="post" asp-action="Login" asp-controller="Auth">
                    
                    <!-- Username / Email -->
                    <div class="mb-3">
                        <label class="form-label" for="UsernameOrEmail">İstifadəçi adı / E-poçt <span>*</span></label>
                        <div class="input-group-custom">
                            <i class="bi bi-person-fill input-icon"></i>
                            <input asp-for="UsernameOrEmail" 
                                   type="text" 
                                   class="form-control-custom @(ViewData.ModelState["UsernameOrEmail"]?.Errors.Count > 0 ? "is-invalid" : "")" 
                                   placeholder="İstifadəçi adı və ya e-poçt yazın" />
                        </div>
                        <span asp-validation-for="UsernameOrEmail" class="field-error"></span>
                    </div>

                    <!-- Password -->
                    <div class="mb-2">
                        <label class="form-label" for="Password">Şifrə <span>*</span></label>
                        <div class="input-group-custom">
                            <i class="bi bi-lock-fill input-icon"></i>
                            <input asp-for="Password" 
                                   type="password" 
                                   id="passwordInput"
                                   class="form-control-custom @(ViewData.ModelState["Password"]?.Errors.Count > 0 ? "is-invalid" : "")" 
                                   placeholder="Şifrənizi daxil edin" />
                            <button type="button" class="toggle-pw" onclick="togglePw('passwordInput', this)">
                                <i class="bi bi-eye"></i>
                            </button>
                        </div>
                        <span asp-validation-for="Password" class="field-error"></span>
                    </div>

                    <!-- Remember Me / Forgot Password -->
                    <div class="remember-forgot">
                        <label class="checkbox-custom" for="RememberMeCheckbox">
                            <input asp-for="RememberMe" type="checkbox" id="RememberMeCheckbox" />
                            Məni xatırla
                        </label>
                        <a href="#" class="forgot-link">Şifrəni unutmusunuz?</a>
                    </div>

                    <button type="submit" class="btn-login">
                        <i class="bi bi-box-arrow-in-right"></i>
                        Daxil Ol
                    </button>
                </form>

                <div class="login-footer">
                    Hesabınız yoxdur? <a asp-controller="Auth" asp-action="Register">Qeydiyyatdan Keçin</a>
                </div>
            </div>

        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.7.1/jquery.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validate/1.21.0/jquery.validate.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validation-unobtrusive/4.0.0/jquery.validate.unobtrusive.min.js"></script>
    <script>
        function togglePw(inputId, btn) {
            const input = document.getElementById(inputId);
            const icon  = btn.querySelector('i');
            if (input.type === 'password') {
                input.type = 'text';
                icon.className = 'bi bi-eye-slash';
            } else {
                input.type = 'password';
                icon.className = 'bi bi-eye';
            }
        }

        function showToast(message, type = 'success') {
            let container = document.getElementById('toast-container');
            if (!container) {
                container = document.createElement('div');
                container.id = 'toast-container';
                container.className = 'toast-container';
                document.body.appendChild(container);
            }
            
            const toast = document.createElement('div');
            toast.className = `toast-item toast-${type}`;
            
            const iconClass = type === 'success' ? 'bi-check-circle-fill' : 'bi-exclamation-triangle-fill';
            
            toast.innerHTML = `
                <i class="bi ${iconClass} toast-icon"></i>
                <div class="toast-message">${message}</div>
            `;
            
            container.appendChild(toast);
            
            // Trigger transition
            setTimeout(() => {
                toast.classList.add('show');
            }, 10);
            
            // Remove after 4 seconds
            setTimeout(() => {
                toast.classList.remove('show');
                toast.classList.add('hide');
                setTimeout(() => {
                    toast.remove();
                }, 400);
            }, 4000);
        }

        @if (TempData["Success"] != null)
        {
            <text>
            showToast("@TempData["Success"]", "success");
            </text>
        }
        @if (TempData["Error"] != null)
        {
            <text>
            showToast("@TempData["Error"]", "error");
            </text>
        }
    </script>
</body>
</html>
